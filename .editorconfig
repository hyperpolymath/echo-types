# SPDX-License-Identifier: PMPL-1.0-or-later
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.agda]
indent_size = 2

[*.rs]
indent_size = 4

[Makefile]
indent_style = tab

[Justfile]
indent_style = tab
